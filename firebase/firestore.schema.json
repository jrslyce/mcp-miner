{
  "schemaVersion": 1,
  "ownerBoundary": "Firebase Auth UID; all player documents live under /players/{uid}",
  "clientWritePolicy": "Clients may write profile/settings/sync metadata and append abstract reward events only. Aggregate game state is Cloud Functions/Admin SDK owned.",
  "privateFieldDenylist": [
    "prompt",
    "prompts",
    "assistantReply",
    "assistantReplies",
    "code",
    "sourceCode",
    "terminalOutput",
    "command",
    "commands",
    "filePath",
    "filePaths",
    "path",
    "paths",
    "cwd",
    "repoName",
    "repository",
    "repositoryName",
    "browserContent",
    "appContent",
    "transcript",
    "rawTranscript"
  ],
  "collections": {
    "players/{uid}": {
      "owner": "uid",
      "clientAccess": ["read", "create", "update"],
      "fields": ["ownerUid", "schemaVersion", "createdAt", "updatedAt", "privacyClass", "displayName", "minerName", "cloudSyncEnabled", "accountLinkedAt"]
    },
    "players/{uid}/profile/current": {
      "owner": "uid",
      "clientAccess": ["read", "create", "update"],
      "fields": ["ownerUid", "schemaVersion", "updatedAt", "privacyClass", "displayName", "minerName", "pronouns", "suitStyle", "avatarConceptPrompt", "customizationUnlocks", "generatedAssetRefs"]
    },
    "players/{uid}/settings/current": {
      "owner": "uid",
      "clientAccess": ["read", "create", "update"],
      "fields": ["ownerUid", "schemaVersion", "updatedAt", "privacyClass", "reportMode", "cloudSyncEnabled", "dashboardTheme", "appCheckDebugEnabled"]
    },
    "players/{uid}/syncMetadata/{clientId}": {
      "owner": "uid",
      "clientAccess": ["read", "create", "update"],
      "fields": ["ownerUid", "schemaVersion", "updatedAt", "privacyClass", "clientId", "clientVersion", "lastLocalEventId", "lastCloudEventId", "lastPulledAt", "lastPushedAt", "conflictState"]
    },
    "players/{uid}/syncDevices/{deviceId}": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true,
      "fields": ["ownerUid", "deviceId", "deviceName", "status", "privacyClass", "scopes", "createdAt", "updatedAt", "lastUsedAt", "revokedAt", "linkSessionId"]
    },
    "players/{uid}/rewardEvents/{eventId}": {
      "owner": "uid",
      "clientAccess": ["read", "create"],
      "appendOnly": true,
      "fields": ["ownerUid", "eventId", "eventType", "schemaVersion", "sequence", "timestamp", "sessionId", "turnId", "observedFields", "privacyClass", "source", "signature", "checksum", "clientCreatedAt", "receivedAt", "reducedAt", "rewardControl"]
    },
    "players/{uid}/gameState/current": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true
    },
    "players/{uid}/inventory/{bucket}": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true
    },
    "players/{uid}/upgrades/current": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true
    },
    "players/{uid}/orders/{orderId}": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true
    },
    "players/{uid}/base/current": {
      "owner": "uid",
      "clientAccess": ["read"],
      "serverOwned": true
    },
    "linkSessions/{sessionId}": {
      "owner": "server",
      "clientAccess": [],
      "serverOwned": true,
      "fields": ["sessionId", "code", "deviceSecretHash", "status", "privacyClass", "deviceName", "createdAt", "updatedAt", "expiresAt", "approvedAt", "approvedUid", "rejectedAt", "rejectedUid", "exchangedAt", "deviceId"]
    },
    "linkCodes/{code}": {
      "owner": "server",
      "clientAccess": [],
      "serverOwned": true,
      "fields": ["code", "sessionId", "status", "privacyClass", "createdAt", "updatedAt", "expiresAt", "approvedUid", "rejectedUid", "deviceId"]
    },
    "deviceTokens/{tokenHash}": {
      "owner": "server",
      "clientAccess": [],
      "serverOwned": true,
      "fields": ["uid", "deviceId", "deviceName", "status", "privacyClass", "scopes", "createdAt", "updatedAt", "lastUsedAt", "revokedAt", "linkSessionId"]
    }
  }
}
